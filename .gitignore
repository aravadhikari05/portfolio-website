# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json

# Environment & secrets (never commit real credentials)
.env
.env.*
!.env.example

# --- Frontend (Vite / React / Node) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Backend: Terraform ---
backend/.terraform/
backend/*.tfstate
backend/*.tfstate.*
backend/crash.log
backend/override.tf
backend/override.tf.json
backend/*_override.tf
backend/*_override.tf.json
backend/.terraform.tfstate.lock.info
# Contains sensitive values — use terraform.tfvars.example + docs instead
backend/terraform.tfvars
backend/*.auto.tfvars
backend/*.auto.tfvars.json
# Local plan output
*.tfplan
*.tfplan.json

# Commit backend/.terraform.lock.hcl (provider version lock)

# --- Backend: Lambda (Terraform archive_file output) ---
backend/lambda/**/*.zip

# --- Backend / Python ---
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/.venv/
backend/venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Tooling ---
.cursor/
